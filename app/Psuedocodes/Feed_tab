// ========================================
// COMPONENT: Feed Screen
// ========================================

STATE VARIABLES:
    array       posts = []                    // List of post objects from server
    boolean     refreshing = false            // Pull-to-refresh indicator

function getAllPosts(isRefresh):
    if isRefresh:
        refreshing = true

    try:
        server_response = await fetch request from server

        if server_response.status != 200:
            throw error

        postsData = server_response.data

        // Ensure vote counters exist
        postsWithInteraction =
            for each post in postsData:
                agreeCount = post.agreeCount or 0
                disagreeCount = post.disagreeCount or 0

        set posts = postsWithInteraction

    catch error:
        log error
        alert fetch failure

    finally:
        if isRefresh:
            refreshing = false


function onRefresh():
    getAllPosts(true)


